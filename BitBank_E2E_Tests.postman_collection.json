{
	"info": {
		"name": "BitBank API - End-to-End",
		"description": "Coleção para testes ponta a ponta da API REST do BitBank. Testa as contas do tipo simples, poupança e bônus.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Criar Conta Simples",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"number\": \"{{acc_simples}}\",\n  \"type\": \"simples\",\n  \"balance\": 1000.0\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/banco/conta/",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"banco",
						"conta",
						""
					]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 201 Created\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"pm.test(\"Verifica saldo inicial\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.balance).to.eql(1000);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			]
		},
